# ============================================================
# Server Configuration
# ============================================================
# Copy to .env and replace all passwords/secrets.
#
# Generate a random password:  openssl rand -base64 24
# Generate a random secret:    openssl rand -hex 32
# ============================================================

# Domain configuration
DOMAIN=example.com
WIKI_DOMAIN=docs.example.com

# Let's Encrypt email for certificate notifications
ACME_EMAIL=admin@example.com

# MariaDB (shared MySQL-compatible database)
# Generate: openssl rand -base64 24
MARIADB_ROOT_PASSWORD=changeme_root_password

# PostgreSQL (shared PostgreSQL database)
# Generate: openssl rand -base64 24
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_password

# WordPress: site1.com
# Generate: openssl rand -base64 24
WP1_DB_NAME=wordpress1
WP1_DB_USER=wordpress1
WP1_DB_PASSWORD=changeme_wp1_password

# WordPress: site2.com
# Generate: openssl rand -base64 24
WP2_DB_NAME=wordpress2
WP2_DB_USER=wordpress2
WP2_DB_PASSWORD=changeme_wp2_password

# Umami Analytics (analytics.example.com)
# Generate password: openssl rand -base64 24
# Generate secret:   openssl rand -hex 32
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=changeme_umami_password
UMAMI_APP_SECRET=changeme_umami_secret

# Uptime Kuma (status.example.com)
# Generate: openssl rand -base64 24
UPTIME_KUMA_DB_NAME=uptime_kuma
UPTIME_KUMA_DB_USER=uptime_kuma
UPTIME_KUMA_DB_PASSWORD=changeme_uptime_kuma_password

# Database monitoring (Alloy -> Prometheus)
# Generate: openssl rand -base64 24
MARIADB_MONITORING_USER=alloy
MARIADB_MONITORING_PASSWORD=changeme_monitoring_mariadb
POSTGRES_MONITORING_USER=alloy
POSTGRES_MONITORING_PASSWORD=changeme_monitoring_postgres

# n8n Workflow Automation (auto.example.com)
# Generate password:        openssl rand -base64 24
# Generate encryption key:  openssl rand -hex 32
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme_n8n_password
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key

# Grafana (stats.example.com)
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# Hetzner Storage Box (offsite backups)
# Get these from your Hetzner Robot panel
STORAGEBOX_HOST=uXXXXXX.your-storagebox.de
STORAGEBOX_USER=uXXXXXX
STORAGEBOX_PORT=23
STORAGEBOX_PATH=./backups

# Timezone
TZ=Europe/Stockholm

# SMTP (shared across services that send email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=changeme
SMTP_PASS=changeme
FROM_EMAIL=noreply@example.com
CONTACT_EMAIL=hello@example.com
